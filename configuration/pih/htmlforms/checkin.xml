<htmlform formUuid="54E29E26-123E-4137-8F26-91D8227C1D5B" formName="Check-In"
          formEncounterType="55a0d3ea-a4d7-4e88-8f01-5aceb2d3c61b" formVersion="2.0">
    <style>
        form input[type="radio"], .form input[type="radio"] {
            float: none;
            display: inline-block;
        }

        .side-by-side label {
            display: inline-block;
        }
    </style>

    <!-- START ENTER/EDIT VERSION OF THE FORM -->
    <ifMode mode="VIEW" include="false">

        <section id="checkin" sectionTag="section" headerStyle="title" headerCode="mirebalais.retrospectiveCheckin.label">

            <fieldset field-separator=", ">
                <legend><uimessage code="pihcore.details"/></legend>
                <h3><uimessage code="pihcore.details"/></h3>
                <subform path="configuration/pih/subforms/encounter-provider-location-date.xml">
                    <label subform-parameter="encounter-provider-label">
                        <uimessage code="mirebalais.retrospectiveCheckin.provider.label"/>
                    </label>
                    <span subform-parameter="encounter-provider-widget">
                        <encounterProviderAndRole default="currentUser"
                                                  encounterRole="cbfe0b9d-9923-404c-941b-f048adc8cdc0"
                                                  required="true"/>
                    </span>
                    <label subform-parameter="encounter-location-label">
                        <uimessage code="mirebalais.retrospectiveCheckin.location.label"/>
                    </label>
                    <span subform-parameter="encounter-location-widget">
                        <encounterLocation default="SessionAttribute:emrContext.sessionLocationId"
                                           tags="Check-In Location"/>
                    </span>
                    <label subform-parameter="encounter-date-label">
                        <uimessage code="mirebalais.retrospectiveCheckin.checkinDate.label"/>
                    </label>
                </subform>
            </fieldset>

           <fieldset class="required type-of-visit-question">
                <legend>
                    <uimessage code="mirebalais.retrospectiveCheckin.visitType.label"/>
                </legend>
                <h3>
                    <uimessage code="mirebalais.retrospectiveCheckin.visitType.label"/>
                </h3>

                <p class="left">
                    <obs conceptId="PIH:REASON FOR VISIT" id="typeOfVisit"
                         answerConceptIds="PIH:OUTPATIENT CONSULTATION, PIH:21420, PIH:ANC VISIT, PIH:MENTAL HEALTH SERVICES, PIH:INPATIENT HOSPITALIZATION, PIH:EMERGENCY VISIT, PIH:NCD Program, PIH:General Surgery, PIH:Obstetrics-Gynecology, PIH:Opthalmology, PIH:MALNUTRITION PROGRAM, PIH:Immunization visit, PIH:Labor and delivery visit, PIH:POSTNATAL VISIT, PIH:ART VISIT, PIH:PMTCT VISIT, PIH:FAMILY PLANNING SERVICES, PIH:TB VISIT, PIH:HOSPITAL PEDIATRICS, PIH:Medical ward, PIH:OTHER NON-CODED"
                         answerLabels="Outpatient, Family Medicine, ANC, Mental Health Clinic, Inpatient, Emergency, NCD Clinic, General Surgery, Obstetrics/Gynecology, Eye Clinic, Malnutrition, EPI, Labor and Delivery, Postnatal, ART Clinic, PMTCT, Family Planning, MDR-TB Clinic ,Peds, Medical ward, Other"
                         style="dropdown" size="999">
                    </obs>
                </p>
            </fieldset>
        </section>

        <section id="patientSupport" sectionTag="section" headerStyle="title" headerCode="pih.registration.patientSupport.section.label">

            <fieldset class="patient-support-questions">
                <legend>
                    <uimessage code="pih.registration.patientSupport.section.label"/>
                </legend>

                <obsgroup groupingConceptId="PIH:14493">
                    <div>
                        <h3><uimessage code="pih.registration.patientSupport.typeOfSupport" /></h3>
                        <p class="side-by-side">
                            <obs conceptId="PIH:6547" id="patientSupportType"
                                 answerConceptIds="PIH:11521,PIH:14646,CIEL:1066,PIH:unknown"
                                 answerCodes="pih.referred,pih.escorted,pihcore.neither,pihcore.notSure"
                                 style="radio" />
                        </p>
                    </div>
                    <br/>


                    <div>
                        <h3><uimessage code="pih.registration.patientSupport.type.label"/></h3>
                        <p>
                            <obs conceptId="PIH:14494" id="patientSupportType"
                                 answerConceptIds="PIH:14496,PIH:14495,PIH:14645,CIEL:1555,PIH:13489,PIH:14502,PIH:14649,PIH:OTHER"
                                 answerCodes="pih.registration.following.type.cha,pih.registration.following.type.chp,pih.registration.following.type.chv,pih.registration.following.type.chwUnspec,pih.registration.following.type.tba,pih.registration.following.type.pssa,pih.registration.selfOrFamily,pihcore.other"
                                 style="dropdown" size="999" />
                        </p>
                    </div>

                    <div>
                        <h3><uimessage code="pih.registration.patientSupport.name.label"/></h3>
                        <p>
                            <obs conceptId="CIEL:164141" id="patientSupportName" size="30" />
                        </p>
                    </div>
                    <br/>

                    <div>
                        <h3><uimessage code="pih.registration.patientSupport.phone.label"/></h3>
                        <p>
                            <obs conceptId="PIH:2614" id="patientSupportPhone" size="30" />
                        </p>
                    </div>

                </obsgroup>
            </fieldset>

        </section>

        <submit/>

    </ifMode>
    <!-- END ENTER/EDIT VERSION OF THE FORM -->

    <!-- START VIEW VERSION OF THE FORM (just display answers to obs, not provider, date, location -->
    <ifMode mode="VIEW">

        <section id="checkin" sectionTag="section" headerStyle="title" headerLabel="">

            <span id="most-recent-encounter-title" style="display:none"><!--The Most Recent Encounter app in Core Apps replaces this with the "most recent" label--></span>

            <fieldset class="type-of-visit-question">
                <legend>
                    <uimessage code="mirebalais.retrospectiveCheckin.visitType.label"/>
                </legend>
                <h3>
                    <uimessage code="mirebalais.retrospectiveCheckin.visitType.label"/>
                </h3>

                <p class="left">
                    <obs conceptId="PIH:REASON FOR VISIT" id="typeOfVisit" showUnits="false"
                         unitsCssClass="append-to-value" style="dropdown" size="9">
                    </obs>
                </p>
            </fieldset>

            <fieldset class="patient-support-questions">
                <legend>
                    <uimessage code="pih.registration.patientSupport.section.label"/>
                </legend>
                <h3>
                    <uimessage code="pih.registration.patientSupport.section.label"/>
                </h3>


                <p class="left">
                    <obsgroup groupingConceptId="PIH:14493">
                        <obs conceptId="PIH:6547" id="patientSupportType" showUnits="false"
                             unitsCssClass="append-to-value" style="dropdown" size="9"/>
                        <obs conceptId="PIH:14494" id="patientSupportRole" showUnits="false"
                             unitsCssClass="append-to-value" style="dropdown" size="9" />
                        <obs conceptId="PIH:6402" id="patientSupportLocation" showUnits="false"
                             unitsCssClass="" style="" size="9" />
                        <obs conceptId="CIEL:164141" id="patientSupportName" showUnits="false"
                             unitsCssClass="" style="" size="9" />
                        <obs conceptId="PIH:2614" id="patientSupportPhone" showUnits="false"
                             unitsCssClass="" style="" size="9" />
                    </obsgroup>
                </p>

            </fieldset>

        </section>

    </ifMode>
    <!-- END VIEW VERSION OF THE FORM -->


</htmlform>
